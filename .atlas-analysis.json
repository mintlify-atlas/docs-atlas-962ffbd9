  "keyFeatures": [
    "Static recompilation of Xbox 360 PowerPC executables to portable C++",
    "Complete Xbox 360 kernel and system call emulation",
    "Cross-platform graphics backends (D3D12 on Windows, Vulkan on Linux)",
    "Audio and input system abstraction",
    "Virtual filesystem with content package support",
    "CLI tooling for project initialization and code generation",
    "Customizable runtime with application framework",
    "Exception handler and debugging support"
  ],
  "publicApiSurface": [
    "rexglue init - Initialize new recompilation project",
    "rexglue codegen - Generate C++ from XEX executable",
    "rexglue migrate - Migrate project to current SDK version",
    "rex::Runtime - Main runtime initialization and subsystem management",
    "rex::ReXApp - Base class for recompiled applications",
    "rex::RuntimeConfig - Runtime backend configuration",
    "rex::codegen::Recompiler - Code generation engine",
    "rex::codegen::RecompilerConfig - Codegen configuration from TOML",
    "rex::memory::Memory - Virtual memory management",
    "rex::filesystem::VirtualFileSystem - VFS abstraction",
    "rex::system::KernelState - Kernel object and thread management",
    "rex::system::IGraphicsSystem - Graphics backend interface",
    "rex::system::IAudioSystem - Audio backend interface",
